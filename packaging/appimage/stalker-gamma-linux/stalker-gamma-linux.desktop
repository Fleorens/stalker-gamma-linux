[Desktop Entry]
# Name= must stay space/paren-free: python-appimage derives the final
# .AppImage filename from it and shells out unquoted (utils/system.py), so a
# display-style name ("S.T.A.L.K.E.R. G.A.M.M.A. (CLI)") breaks the build.
Type=Application
Name=stalker-gamma-linux
Comment=Install and play S.T.A.L.K.E.R. G.A.M.M.A. on Linux (command line)
Exec=stalker-gamma-linux
Icon=stalker-gamma-linux
Categories=Game;
Terminal=true
